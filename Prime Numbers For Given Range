# Input range
start = int(input())
end = int(input())

# Function to check if a number is prime
def is_prime(n):
	if n <= 1:
		return False
	for i in range(2, int(n**0.5) + 1):
		if n % i == 0:
			return False
	return True

# Flag to check if any prime exists
found_prime = False

# Iterate through the range
for num in range(start, end + 1):
	if is_prime(num):
		print(num)
		found_prime = True

if not found_prime:
	print("No primes")
